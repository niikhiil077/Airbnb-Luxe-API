<!DOCTYPE html>
<html lang="en">

<head>
    <meta name="viewport" content="width=device-width , initial-scale=1.0">
    <meta charset="UTF-8">
    <title>Home Added - Airbnb</title>
    <style>
        /* ===== RESET + THEME ===== */
        *,
        *::before,
        *::after {
            box-sizing: border-box;
        }

        :root {
            --accent: #ff385c;
            --accent-hover: #e03150;
            --bg: #f7f7f7;
            --border: #e5e5e5;
            --text: #222;
        }

        body {
            margin: 0;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            background: var(--bg);
            color: var(--text);
            -webkit-font-smoothing: antialiased;
        }

        /* ===== NAVBAR ===== */
        nav {
            background: #fff;
            padding: clamp(12px, 3vw, 20px) clamp(16px, 5vw, 60px);
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
            justify-content: space-between;
            align-items: center;
            border-bottom: 1px solid var(--border);
            position: sticky;
            top: 0;
            z-index: 100;
        }

        nav .logo {
            font-size: clamp(1.2rem, 4vw, 1.6rem);
            font-weight: 700;
            color: var(--accent);
        }

        nav ul {
            list-style: none;
            display: flex;
            flex-wrap: wrap;
            justify-content: flex-end;
            gap: 8px;
            margin: 0;
            padding: 0;
            width: 100%;
        }

        nav ul li a {
            text-decoration: none;
            color: var(--text);
            font-weight: 500;
            padding: 10px 14px;
            border-radius: 999px;
            transition: background 0.2s ease;
            display: inline-block;
        }

        nav ul li a:hover {
            background: #f2f2f2;
        }

        /* ===== SUCCESS CARD ===== */
        .success-container {
            width: min(92%, 620px);
            margin: clamp(40px, 8vw, 120px) auto;
            text-align: center;
            background: #fff;
            padding: clamp(28px, 6vw, 56px);
            border-radius: clamp(16px, 3vw, 22px);
            box-shadow: 0 12px 36px rgba(0, 0, 0, 0.08);
            animation: fadeIn 0.5s ease;
        }

        /* subtle entrance animation */
        @keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(12px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .success-container h2 {
            font-size: clamp(1.6rem, 6vw, 2.4rem);
            margin-bottom: clamp(14px, 3vw, 22px);
            font-weight: 650;
        }

        .success-container p {
            font-size: clamp(1rem, 3.5vw, 1.2rem);
            margin-bottom: clamp(24px, 5vw, 40px);
            color: #555;
        }

        /* ===== BUTTON LINK ===== */
        .success-container a {
            display: inline-block;
            padding: clamp(14px, 4vw, 18px) clamp(22px, 6vw, 34px);
            border-radius: 999px;
            background: var(--accent);
            color: #fff;
            font-size: clamp(1rem, 4vw, 1.1rem);
            font-weight: 600;
            text-decoration: none;
            transition: background 0.2s ease, transform 0.1s ease;
            touch-action: manipulation;
        }

        .success-container a:hover {
            background: var(--accent-hover);
            transform: translateY(-1px);
        }

        .success-container a:active {
            transform: scale(0.98);
        }

        /* ===== TABLET FIX ===== */
        @media (min-width: 640px) {
            nav ul {
                width: auto;
            }
        }

        /* ===== DESKTOP POLISH ===== */
        @media (min-width: 1024px) {
            .success-container:hover {
                box-shadow: 0 20px 48px rgba(0, 0, 0, 0.12);
            }
        }

        /* ===== SMALL PHONE FIX ===== */
        @media (max-width: 360px) {
            nav ul {
                justify-content: center;
            }
        }

        /* ===== NAVBAR BASE ===== */
        .navbar {
            background: linear-gradient(90deg, #1a1a2e, #16213e);
            padding: clamp(14px, 4vw, 18px) clamp(16px, 6vw, 50px);

            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 12px;

            box-shadow: 0 6px 12px rgba(0, 0, 0, 0.3);
        }

        /* ===== LOGO ===== */
        .logo {
            font-size: clamp(1.4rem, 3.5vw, 1.8rem);
            font-weight: 700;
            color: #ffd700;
            letter-spacing: 2px;
        }

        /* ===== NAV LINKS ===== */
        .nav-links {
            list-style: none;
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
            margin: 0;
            padding: 0;
        }

        .nav-links li {
            margin: 0;
        }

        .nav-links a {
            text-decoration: none;
            color: #f8f9fa;
            font-weight: 500;
            padding: 8px 14px;
            border-radius: 20px;
            font-size: clamp(0.85rem, 2.8vw, 1rem);
            transition: 0.25s ease;
        }

        .nav-links a:hover {
            background: #ffd700;
            color: #1a1a2e;
        }

        /* ===== BUTTON SYSTEM ===== */
        .btn {
            padding: 8px 16px;
            border-radius: 25px;
            font-weight: bold;
            cursor: pointer;
            border: none;
            font-size: 0.9rem;
            transition: 0.25s ease;
            text-decoration: none;
            display: inline-block;
        }

        /* Logout button */
        .logout-btn {
            background: rgb(143, 152, 17);
            color: white;
            border: 2px solid rgb(167, 167, 131);
        }

        .logout-btn:hover {
            background: rgb(165, 175, 25);
            transform: translateY(-1px);
        }

        /* Auth buttons */
        .auth-buttons {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
        }

        .auth-btn {
            background: rgb(20, 158, 200);
            color: white;
            border: 2px solid white;
        }

        .auth-btn:hover {
            background: rgb(15, 130, 170);
            transform: translateY(-1px);
        }

        /* Fix form inside navbar */
        .inline-form {
            margin: 0;
        }

        /* ===== MOBILE RESPONSIVE ===== */
        @media (max-width: 600px) {

            .navbar {
                flex-direction: column;
                align-items: flex-start;
            }

            .nav-links {
                width: 100%;
            }

            .auth-buttons {
                width: 100%;
            }

            .btn {
                width: 100%;
                text-align: center;
            }
        }
        
    </style>

</head>

<body>

    <%-include ('partials/navbar') %>

        <!-- Success Message -->
        <div class="success-container">
            <h2>🎉 Home Successfully Added!</h2>
            <p>Your property has been added to our listings.</p>
            <a href="/host/homelist">Back to Home List</a>
        </div>
</body>

</html>