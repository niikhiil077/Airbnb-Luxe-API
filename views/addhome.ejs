<!DOCTYPE html>
<html lang="en">

<head>
    <meta name="viewport" content="width=device-width , initial-scale=1.0">
    <meta charset="UTF-8">
    <title>Add Home - Airbnb</title>
    <style>
        /* ===== CSS RESET + BASE ===== */
        *,
        *::before,
        *::after {
            box-sizing: border-box;
        }

        :root {
            --accent: #ff385c;
            --accent-hover: #e03150;
            --bg: #f7f7f7;
            --border: #e5e5e5;
            --text: #222;
        }

        body {
            margin: 0;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            background: var(--bg);
            color: var(--text);
            -webkit-font-smoothing: antialiased;
        }

        /* ===== NAVBAR (Mobile-first) ===== */
        nav {
            background: #fff;
            padding: clamp(12px, 3vw, 20px) clamp(16px, 5vw, 60px);
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
            justify-content: space-between;
            align-items: center;
            border-bottom: 1px solid var(--border);
            position: sticky;
            top: 0;
            z-index: 100;
        }

        nav .logo {
            font-size: clamp(1.2rem, 4vw, 1.6rem);
            font-weight: 700;
            color: var(--accent);
        }

        nav ul {
            list-style: none;
            display: flex;
            flex-wrap: wrap;
            justify-content: flex-end;
            gap: 8px;
            margin: 0;
            padding: 0;
            width: 100%;
        }

        nav ul li a {
            text-decoration: none;
            color: var(--text);
            font-weight: 500;
            padding: 10px 14px;
            border-radius: 999px;
            transition: background 0.2s ease;
            display: inline-block;
        }

        nav ul li a:hover {
            background: #f2f2f2;
        }

        /* ===== FORM WRAPPER ===== */
        .form-container {
            width: min(92%, 640px);
            margin: clamp(30px, 6vw, 80px) auto;
            background: #fff;
            padding: clamp(20px, 5vw, 48px);
            border-radius: clamp(14px, 3vw, 20px);
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
        }

        .form-container h2 {
            text-align: center;
            margin-bottom: clamp(20px, 4vw, 36px);
            font-size: clamp(1.4rem, 5vw, 2rem);
            font-weight: 600;
        }

        /* ===== FORM FIELDS ===== */
        .form-group {
            margin-bottom: clamp(16px, 3vw, 24px);
        }

        .form-group label {
            display: block;
            margin-bottom: 8px;
            font-size: 0.95rem;
            font-weight: 500;
            color: #444;
        }

        .form-group input,
        .form-group textarea {
            width: 100%;
            padding: clamp(12px, 3.5vw, 16px);
            border-radius: 14px;
            border: 1px solid var(--border);
            font-size: 1rem;
            background: #fff;
            transition: border 0.2s ease, box-shadow 0.2s ease;
        }

        textarea {
            resize: vertical;
            min-height: 110px;
        }

        .form-group input:focus,
        .form-group textarea:focus {
            border-color: var(--accent);
            box-shadow: 0 0 0 3px rgba(255, 56, 92, 0.15);
            outline: none;
        }

        /* ===== BUTTON ===== */
        .form-container button {
            width: 100%;
            padding: clamp(14px, 4vw, 18px);
            border-radius: 999px;
            border: none;
            background: var(--accent);
            color: white;
            font-size: clamp(1rem, 4vw, 1.15rem);
            font-weight: 600;
            cursor: pointer;
            transition: background 0.2s ease, transform 0.1s ease;
            touch-action: manipulation;
        }

        .form-container button:hover {
            background: var(--accent-hover);
            transform: translateY(-1px);
        }

        .form-container button:active {
            transform: scale(0.98);
        }

        /* ===== TABLET OPTIMIZATION ===== */
        @media (min-width: 640px) {
            nav ul {
                width: auto;
            }
        }

        /* ===== DESKTOP POLISH ===== */
        @media (min-width: 1024px) {
            .form-container {
                backdrop-filter: blur(4px);
            }

            .form-container:hover {
                box-shadow: 0 18px 40px rgba(0, 0, 0, 0.12);
            }
        }

        /* ===== SMALL PHONE FIXES ===== */
        @media (max-width: 360px) {
            nav ul {
                justify-content: center;
            }

            .form-container {
                border-radius: 12px;
            }
        }

        /* ===== HOMEPAGE STYLE NAVBAR (Clean SaaS + Responsive) ===== */

        .navbar {
            position: sticky;
            top: 0;
            z-index: 1000;

            width: 100%;
            background: #ffffff;
            border-bottom: 1px solid #e5e7eb;

            padding: clamp(12px, 3vw, 18px) clamp(16px, 6vw, 60px);

            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 12px;
        }

        /* ===== LOGO ===== */
        .logo {
            font-size: clamp(1.3rem, 3.5vw, 1.6rem);
            font-weight: 700;
            color: #111827;
            letter-spacing: -0.2px;
        }

        /* ===== NAV LINKS ===== */
        .nav-links {
            list-style: none;
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
            margin: 0;
            padding: 0;
        }

        .nav-links li {
            margin: 0;
        }

        .nav-links a {
            text-decoration: none;
            color: #374151;
            font-weight: 500;
            font-size: clamp(0.85rem, 2.6vw, 0.95rem);

            padding: 8px 14px;
            border-radius: 8px;
            transition: background 0.2s ease, color 0.2s ease;
        }

        .nav-links a:hover {
            background: #f3f4f6;
            color: #111827;
        }

        /* ===== BUTTON SYSTEM ===== */
        .btn {
            padding: 8px 16px;
            border-radius: 8px;
            font-weight: 600;
            font-size: 0.9rem;

            cursor: pointer;
            border: none;
            text-decoration: none;
            display: inline-block;

            transition: background 0.2s ease, transform 0.1s ease;
        }

        .btn:active {
            transform: scale(0.97);
        }

        /* Login / Signup buttons */
        .auth-btn {
            background: #111827;
            color: #ffffff;
        }

        .auth-btn:hover {
            background: #2563eb;
        }

        /* Logout button */
        .logout-btn {
            background: #ef4444;
            color: #ffffff;
        }

        .logout-btn:hover {
            background: #dc2626;
        }

        /* Fix form inside navbar */
        .inline-form {
            margin: 0;
        }

        /* ===== TABLET LAYOUT ===== */
        @media (min-width: 640px) {
            .nav-links {
                width: auto;
            }
        }

        /* ===== MOBILE RESPONSIVE ===== */
        @media (max-width: 600px) {
            .navbar {
                flex-direction: column;
                align-items: flex-start;
            }

            .nav-links {
                width: 100%;
                justify-content: flex-start;
            }

            .btn {
                width: 100%;
                text-align: center;
            }
        }

        /* ===== SMALL PHONE FIX ===== */
        @media (max-width: 360px) {
            .nav-links {
                justify-content: center;
            }
        }
    </style>


</head>

<body>


    <%-include ('partials/navbar') %>


        <!-- Add Home Form -->
        <div class="form-container">

            <h2>
                <%= editMode? 'Edit your home' : 'Add your new home' %>
            </h2>
            <form action="<%= editMode ? '/host/edithome/' + home._id : '/host/homeadded' %>" method="post">
                <input type="hidden" name="id" value="<%= editMode ? home._id : ''%>" />
                <div class="form-group">
                    <label for="houseName">House Name</label>
                    <input type="text" id="houseName" name="houseName" value="<%= editMode?  home.houseName : '' %>">
                </div>

                <div class="form-group">
                    <label for="price">Price</label>
                    <input type="number" id="price" name="price" value="<%= editMode?  home.price  : '' %>">
                </div>

                <div class="form-group">
                    <label for="location">Location</label>
                    <input type="text" id="location" name="location" value="<%= editMode?  home.location  : '' %>">
                </div>

                <div class="form-group">
                    <label for="description">Description</label>
                    <textarea id="description" name="description" rows="4">
                    <%= editMode? home.description  : '' %>
                </textarea>
                </div>

                <div class="form-group">
                    <label for="photoUrl">Photo URL</label>
                    <input type="url" id="photoUrl" name="photoUrl" value="<%= editMode?  home.photoUrl  : '' %>">
                </div>

                <button type="submit">Add Home</button>
            </form>

        </div>
</body>

</html>