<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <title>No Homes Added - Airbnb Luxe</title>
  <style>
    /* ===== RESET ===== */
    * {
      box-sizing: border-box;
    }

    body {
      margin: 0;
      font-family: 'Poppins', sans-serif;
      background: linear-gradient(to right, #0f2027, #203a43, #2c5364);
      color: #f8f9fa;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }

    /* ===== NAVBAR ===== */
    nav {
      background: linear-gradient(90deg, #1a1a2e, #16213e);
      padding: clamp(14px, 4vw, 18px) clamp(16px, 6vw, 50px);
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
      gap: 10px;
      box-shadow: 0 6px 12px rgba(0, 0, 0, 0.3);
    }

    nav .logo {
      font-size: clamp(1.4rem, 3.5vw, 1.8rem);
      font-weight: 700;
      color: #ffd700;
      letter-spacing: 2px;
    }

    nav ul {
      list-style: none;
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin: 0;
      padding: 0;
    }

    nav ul li {
      margin: 0;
    }

    nav ul li a {
      text-decoration: none;
      color: #f8f9fa;
      font-weight: 500;
      padding: 8px 14px;
      border-radius: 20px;
      font-size: clamp(0.85rem, 2.8vw, 1rem);
      transition: 0.25s ease;
    }

    nav ul li a:hover {
      background: #ffd700;
      color: #1a1a2e;
    }

    /* ===== PAGE CENTERING ===== */
    body>.empty-container {
      margin: auto;
    }

    /* ===== EMPTY CONTAINER ===== */
    .empty-container {
      width: min(92%, 600px);
      text-align: center;
      background: rgba(255, 255, 255, 0.06);
      backdrop-filter: blur(14px);
      padding: clamp(28px, 6vw, 60px);
      border-radius: 20px;
      box-shadow: 0 8px 20px rgba(0, 0, 0, 0.4);
      animation: fadeIn 0.8s ease;
    }

    /* Animation */
    @keyframes fadeIn {
      from {
        opacity: 0;
        transform: translateY(20px);
      }

      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    .empty-container .icon {
      font-size: clamp(3rem, 10vw, 5rem);
      margin-bottom: 16px;
    }

    .empty-container h2 {
      font-size: clamp(1.5rem, 4.5vw, 2.2rem);
      margin-bottom: 12px;
      color: #ffd700;
    }

    .empty-container p {
      font-size: clamp(0.95rem, 3vw, 1.2rem);
      margin-bottom: 28px;
      color: #f1f1f1;
      line-height: 1.5;
    }

    /* ===== BUTTON ===== */
    .empty-container a {
      display: inline-block;
      padding: 12px 26px;
      border-radius: 30px;
      background: linear-gradient(90deg, #ffd700, #ff9f1c);
      color: #1a1a2e;
      font-size: clamp(0.95rem, 3vw, 1.1rem);
      font-weight: bold;
      text-decoration: none;
      transition: 0.25s ease;
    }

    .empty-container a:hover {
      transform: translateY(-2px) scale(1.03);
      box-shadow: 0 6px 15px rgba(0, 0, 0, 0.4);
    }

    /* ===== SMALL MOBILE FIXES ===== */
    @media (max-width: 420px) {
      nav {
        flex-direction: column;
        align-items: flex-start;
      }

      nav ul {
        width: 100%;
        justify-content: flex-start;
      }
    }

    /* ===== NAVBAR BASE ===== */
    .navbar {
      background: linear-gradient(90deg, #1a1a2e, #16213e);
      padding: clamp(14px, 4vw, 18px) clamp(16px, 6vw, 50px);

      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
      gap: 12px;

      box-shadow: 0 6px 12px rgba(0, 0, 0, 0.3);
    }

    /* ===== LOGO ===== */
    .logo {
      font-size: clamp(1.4rem, 3.5vw, 1.8rem);
      font-weight: 700;
      color: #ffd700;
      letter-spacing: 2px;
    }

    /* ===== NAV LINKS ===== */
    .nav-links {
      list-style: none;
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      margin: 0;
      padding: 0;
    }

    .nav-links li {
      margin: 0;
    }

    .nav-links a {
      text-decoration: none;
      color: #f8f9fa;
      font-weight: 500;
      padding: 8px 14px;
      border-radius: 20px;
      font-size: clamp(0.85rem, 2.8vw, 1rem);
      transition: 0.25s ease;
    }

    .nav-links a:hover {
      background: #ffd700;
      color: #1a1a2e;
    }

    /* ===== BUTTON SYSTEM ===== */
    .btn {
      padding: 8px 16px;
      border-radius: 25px;
      font-weight: bold;
      cursor: pointer;
      border: none;
      font-size: 0.9rem;
      transition: 0.25s ease;
      text-decoration: none;
      display: inline-block;
    }

    /* Logout button */
    .logout-btn {
      background: rgb(143, 152, 17);
      color: white;
      border: 2px solid rgb(167, 167, 131);
    }

    .logout-btn:hover {
      background: rgb(165, 175, 25);
      transform: translateY(-1px);
    }

    /* Auth buttons */
    .auth-buttons {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
    }

    .auth-btn {
      background: rgb(20, 158, 200);
      color: white;
      border: 2px solid white;
    }

    .auth-btn:hover {
      background: rgb(15, 130, 170);
      transform: translateY(-1px);
    }

    /* Fix form inside navbar */
    .inline-form {
      margin: 0;
    }

    /* ===== MOBILE RESPONSIVE ===== */
    @media (max-width: 600px) {

      .navbar {
        flex-direction: column;
        align-items: flex-start;
      }

      .nav-links {
        width: 100%;
      }

      .auth-buttons {
        width: 100%;
      }

      .btn {
        width: 100%;
        text-align: center;
      }
    }
    
  </style>
</head>

<body>

  <%-include ('partials/navbar') %>

    <!-- Empty State -->
    <div class="empty-container">
      <div class="icon">🏠</div>
      <h2>No Homes Added Yet</h2>
      <p>Start building your luxury listings by adding your first home.</p>
      <a href="/host/addhome">Add a Home</a>
    </div>
</body>

</html>