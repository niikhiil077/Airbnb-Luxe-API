<!DOCTYPE html>
<html lang="en">

<head>
    <meta name="viewport" content="width=device-width , initial-scale=1.0">
    <meta charset="UTF-8">
    <title>Airbnb</title>
    <style>
        /* ===== RESET ===== */
        *,
        *::before,
        *::after {
            box-sizing: border-box;
        }

        :root {
            --bg: #f8fafc;
            --card: #ffffff;
            --text: #111827;
            --muted: #6b7280;
            --border: #e5e7eb;
            --primary: #111827;
            --primary-hover: #2563eb;
        }

        body {
            margin: 0;
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
            background: var(--bg);
            color: var(--text);
        }

        /* ===== NAVBAR (Professional SaaS) ===== */
        .navbar {
            position: sticky;
            top: 0;
            z-index: 1000;

            width: 100%;
            background: #ffffff;
            padding: 16px clamp(20px, 6vw, 60px);

            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 12px;

            border-bottom: 1px solid var(--border);
        }

        .logo {
            font-size: 1.5rem;
            font-weight: 700;
            color: var(--text);
        }

        .nav-links {
            list-style: none;
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
            margin: 0;
            padding: 0;
        }

        .nav-links a {
            text-decoration: none;
            color: #374151;
            font-weight: 500;
            padding: 8px 14px;
            border-radius: 8px;
            transition: 0.2s ease;
        }

        .nav-links a:hover {
            background: #f3f4f6;
        }

        /* Buttons */
        .btn {
            padding: 8px 16px;
            border-radius: 8px;
            font-weight: 600;
            cursor: pointer;
            border: none;
            font-size: 0.9rem;
            transition: 0.2s ease;
            text-decoration: none;
            display: inline-block;
        }

        .auth-btn {
            background: var(--primary);
            color: white;
        }

        .auth-btn:hover {
            background: var(--primary-hover);
        }

        .logout-btn {
            background: #ef4444;
            color: white;
        }

        .logout-btn:hover {
            background: #dc2626;
        }

        .inline-form {
            margin: 0;
        }

        /* ===== HERO SECTION (Clean SaaS Landing) ===== */
        .hero {
            min-height: calc(100vh - 72px);

            display: flex;
            align-items: center;
            justify-content: center;
            text-align: center;

            padding: clamp(60px, 10vw, 140px) 20px;

            background:
                radial-gradient(circle at top, #ffffff 0%, #eef2f7 40%, #e5eaf1 100%);
        }

        .hero-content {
            max-width: 860px;
            animation: fadeIn 0.6s ease;
        }

        @keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(18px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* Hero text */
        .hero h1 {
            font-size: clamp(2.2rem, 7vw, 3.8rem);
            margin-bottom: 18px;
            font-weight: 700;
            letter-spacing: -0.02em;
        }

        .hero p {
            font-size: clamp(1.05rem, 3.5vw, 1.35rem);
            color: var(--muted);
            margin-bottom: 36px;
            line-height: 1.6;
        }

        /* CTA Button */
        .hero button {
            padding: 16px 34px;
            font-size: 1.05rem;
            border-radius: 12px;
            border: none;
            background: var(--primary);
            color: white;
            font-weight: 600;
            cursor: pointer;
            transition: 0.2s ease;
        }

        .hero button:hover {
            background: var(--primary-hover);
            transform: translateY(-1px);
        }

        .hero button:active {
            transform: scale(0.98);
        }

        /* ===== MOBILE RESPONSIVE ===== */
        @media (max-width: 600px) {
            .navbar {
                flex-direction: column;
                align-items: flex-start;
            }

            .btn {
                width: 100%;
                text-align: center;
            }
        }

        @media (max-width: 420px) {
            .hero {
                padding: 80px 16px;
            }
        }
    </style>


</head>

<body>
    <!-- Navigation Bar -->

    <%-include ('partials/navbar') %>

        <!-- Hero Section -->
        <section class="hero">
            <div class="hero-content">
                <h1>Discover Luxury Stays</h1>
                <p>Experience premium homes and unforgettable journeys worldwide.</p>
                <button>Explore Now</button>
            </div>
        </section>
</body>

</html>